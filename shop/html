<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="World Of Fancie — A Luxury Virtual Shopping Experience by Fancies World">
<title>World Of Fancie | Fancies World</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
:root{
  --g:#C9A84C; --gl:rgba(201,168,76,.3); --gd:rgba(201,168,76,.08);
  --blk:#0A0A0A; --blks:#141414; --blkm:#1A1A1A;
  --wht:#FAFAF8; --tan:#C4A882; --cream:#F5EDD8; --champ:#EEE0C0;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Inter',sans-serif;background:var(--blk);color:var(--wht);overflow-x:hidden;}
h1,h2,h3,h4{font-family:'Cormorant Garamond',serif;font-weight:400;line-height:1.15;}
a{color:var(--g);text-decoration:none;}
img{max-width:100%;}
.btn{display:inline-block;padding:12px 28px;font-family:'Inter',sans-serif;font-size:11px;font-weight:500;letter-spacing:1.5px;text-transform:uppercase;border:none;cursor:pointer;transition:all .25s;}
.btn-gold{background:var(--g);color:var(--blk);}
.btn-gold:hover{background:#DDB955;color:var(--blk);}
.btn-outline-gold{background:transparent;border:1px solid var(--g);color:var(--g);}
.btn-outline-gold:hover{background:var(--g);color:var(--blk);}
.btn-outline-white{background:transparent;border:1px solid rgba(255,255,255,.3);color:rgba(255,255,255,.7);}
.btn-outline-white:hover{border-color:var(--g);color:var(--g);}
.lbl{font-size:9px;letter-spacing:3px;text-transform:uppercase;}
.divider{width:60px;height:1px;background:var(--g);margin:14px auto;opacity:.6;}

/* ANIMATIONS */
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
@keyframes glow{0%,100%{box-shadow:0 0 20px var(--gl)}50%{box-shadow:0 0 50px rgba(201,168,76,.5)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
@keyframes shimmer{0%{background-position:-200% center}100%{background-position:200% center}}
@keyframes pulse{0%,100%{opacity:.6}50%{opacity:1}}
@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
@keyframes doorGlow{0%,100%{border-color:rgba(201,168,76,.35)}50%{border-color:rgba(201,168,76,.8)}}

/* TRANSITION OVERLAY */
#overlay{position:fixed;inset:0;background:var(--blk);z-index:9998;opacity:0;pointer-events:none;transition:opacity .45s;}
#overlay.on{opacity:1;pointer-events:all;}

/* MALL NAV */
#mall-nav{position:fixed;top:0;left:0;right:0;z-index:999;background:rgba(10,10,10,.96);border-bottom:1px solid var(--gl);padding:0 5%;display:flex;align-items:center;justify-content:space-between;height:64px;}
.nav-logo{font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:var(--wht);cursor:pointer;letter-spacing:1px;}
.nav-logo span{color:var(--g);}
.nav-links{display:flex;gap:24px;list-style:none;align-items:center;}
.nav-links a,.nav-links button{font-size:10px;letter-spacing:1px;text-transform:uppercase;color:rgba(255,255,255,.5);background:none;border:none;cursor:pointer;font-family:'Inter',sans-serif;transition:color .2s;padding:0;}
.nav-links a:hover,.nav-links button:hover,.nav-links a.active{color:var(--g);}
.nav-wish{display:flex;align-items:center;gap:6px;font-size:10px;color:rgba(255,255,255,.4);cursor:pointer;letter-spacing:.5px;transition:color .2s;}
.nav-wish:hover{color:var(--g);}
.wish-count{background:var(--g);color:var(--blk);width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:500;}
.back-site{font-size:10px;color:rgba(255,255,255,.35);letter-spacing:.5px;border:1px solid rgba(255,255,255,.12);padding:6px 12px;transition:all .2s;}
.back-site:hover{border-color:var(--g);color:var(--g);}

/* VIEWS */
.view{display:none;padding-top:64px;min-height:100vh;animation:fadeUp .5s ease both;}
.view.active{display:block;}

/* ═══ LOBBY ════════════════════════════════════════════════════ */
#view-lobby{}

.lobby-hero{min-height:92vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:80px 5% 60px;position:relative;overflow:hidden;background:var(--blk);}
.hero-particles{position:absolute;inset:0;pointer-events:none;}
.particle{position:absolute;width:2px;height:2px;background:var(--g);border-radius:50%;animation:float 4s ease-in-out infinite;opacity:.4;}
.hero-eyebrow{font-size:9px;letter-spacing:5px;text-transform:uppercase;color:rgba(201,168,76,.55);margin-bottom:20px;animation:pulse 3s ease infinite;}
.hero-title{font-size:clamp(3rem,8vw,7rem);color:var(--wht);margin-bottom:6px;letter-spacing:3px;line-height:1;}
.hero-title span{color:var(--g);}
.hero-sub-title{font-size:clamp(1rem,2.5vw,1.6rem);color:rgba(255,255,255,.3);letter-spacing:6px;text-transform:uppercase;margin-bottom:20px;font-family:'Cormorant Garamond',serif;font-style:italic;}
.hero-divider{display:flex;align-items:center;gap:16px;margin:0 auto 28px;width:280px;}
.hero-divider-line{flex:1;height:1px;background:linear-gradient(90deg,transparent,var(--g),transparent);}
.hero-divider-diamond{width:6px;height:6px;background:var(--g);transform:rotate(45deg);flex-shrink:0;}
.hero-desc{font-size:13px;color:rgba(255,255,255,.4);max-width:440px;line-height:1.8;margin-bottom:36px;}
.hero-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}
.scroll-hint{margin-top:48px;font-size:10px;letter-spacing:2px;color:rgba(255,255,255,.2);text-transform:uppercase;animation:float 2.5s ease-in-out infinite;}

/* STOREFRONTS HALL */
.hall{padding:80px 5%;background:var(--blks);}
.hall-header{text-align:center;margin-bottom:56px;}
.hall-header h2{font-size:clamp(2rem,4vw,3rem);color:var(--wht);}
.hall-header p{font-size:12px;color:rgba(255,255,255,.35);margin-top:8px;letter-spacing:1px;}
.doors-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:24px;max-width:1100px;margin:0 auto;}

.store-door{position:relative;height:340px;cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:space-between;padding:24px 18px;border:2px solid rgba(201,168,76,.25);background:var(--blkm);transition:all .35s;overflow:hidden;animation:doorGlow 4s ease-in-out infinite;}
.store-door::before{content:'';position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(201,168,76,.06) 100%);transition:opacity .35s;opacity:0;}
.store-door:hover{border-color:var(--g);transform:translateY(-4px);}
.store-door:hover::before{opacity:1;}
.door-top-bar{width:100%;height:2px;background:linear-gradient(90deg,transparent,var(--g),transparent);opacity:.5;transition:opacity .3s;}
.store-door:hover .door-top-bar{opacity:1;}
.door-icon{font-size:2.8rem;animation:float 4s ease-in-out infinite;filter:drop-shadow(0 0 12px rgba(201,168,76,.3));}
.door-knob{width:12px;height:12px;border-radius:50%;background:var(--g);position:absolute;right:14px;top:50%;box-shadow:0 0 8px var(--g);}
.door-info{text-align:center;}
.door-name{font-family:'Cormorant Garamond',serif;font-size:1.35rem;color:var(--wht);margin-bottom:5px;letter-spacing:1px;}
.door-cat{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.65);}
.door-enter{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.2);transition:color .3s;margin-top:8px;}
.store-door:hover .door-enter{color:var(--g);}
.door-bot-bar{width:100%;height:2px;background:linear-gradient(90deg,transparent,var(--g),transparent);opacity:.5;transition:opacity .3s;}
.store-door:hover .door-bot-bar{opacity:1;}
.door-glow-bg{position:absolute;width:150%;height:150%;background:radial-gradient(circle,rgba(201,168,76,.04) 0%,transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);opacity:0;transition:opacity .4s;}
.store-door:hover .door-glow-bg{opacity:1;}

/* FEATURED FLOOR */
.featured-floor{padding:80px 5%;background:var(--cream);}
.featured-floor .lbl{color:var(--g);display:block;text-align:center;margin-bottom:8px;}
.featured-floor h2{font-size:clamp(1.8rem,3.5vw,2.6rem);color:var(--blk);text-align:center;}
.featured-floor p{font-size:12px;color:var(--tan);text-align:center;margin-top:8px;letter-spacing:.5px;}
.products-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:2px;background:var(--champ);margin-top:40px;max-width:1100px;margin-left:auto;margin-right:auto;}
.prod-card{background:var(--wht);padding:24px;cursor:pointer;transition:background .25s;text-align:center;}
.prod-card:hover{background:var(--champ);}
.prod-card .prod-img{background:var(--champ);padding:20px 0;font-size:3rem;margin-bottom:16px;transition:background .25s;}
.prod-card:hover .prod-img{background:var(--wht);}
.prod-card .prod-cat{font-size:8px;letter-spacing:2px;text-transform:uppercase;color:var(--g);margin-bottom:5px;}
.prod-card .prod-name{font-family:'Cormorant Garamond',serif;font-size:1.05rem;color:var(--blk);margin-bottom:4px;}
.prod-card .prod-store{font-size:9px;letter-spacing:1px;text-transform:uppercase;color:var(--tan);margin-bottom:8px;}
.prod-card .prod-price{font-family:'Cormorant Garamond',serif;font-size:1.15rem;color:var(--g);margin-bottom:12px;}
.prod-card .prod-action{font-size:8px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(0,0,0,.25);border-top:1px solid var(--champ);padding-top:10px;}

/* LOUNGE PREVIEW */
.lounge-preview{padding:80px 5%;background:var(--blk);text-align:center;}
.lounge-preview .lbl{color:rgba(201,168,76,.6);display:block;margin-bottom:12px;}
.lounge-preview h2{font-size:clamp(1.8rem,3.5vw,2.8rem);color:var(--wht);}
.lounge-preview p{font-size:13px;color:rgba(255,255,255,.35);max-width:480px;margin:12px auto 32px;line-height:1.8;}
.campaign-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:2px;max-width:900px;margin:40px auto 0;background:rgba(201,168,76,.1);}
.campaign-card{background:var(--blks);padding:32px 24px;text-align:center;}
.campaign-card .c-icon{font-size:2.5rem;margin-bottom:14px;}
.campaign-card .c-title{font-family:'Cormorant Garamond',serif;font-size:1.15rem;color:var(--wht);margin-bottom:6px;}
.campaign-card .c-desc{font-size:11px;color:rgba(255,255,255,.35);line-height:1.7;}

/* ═══ STORE ROOMS ══════════════════════════════════════════════ */
.store-back{position:sticky;top:64px;z-index:100;padding:10px 5%;display:flex;align-items:center;gap:16px;border-bottom:1px solid rgba(255,255,255,.07);}
.store-back button{background:transparent;border:1px solid rgba(201,168,76,.3);color:var(--g);padding:7px 16px;font-size:9px;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;font-family:'Inter',sans-serif;transition:all .2s;}
.store-back button:hover{background:var(--g);color:var(--blk);}
.store-back .breadcrumb{font-size:10px;color:rgba(255,255,255,.25);letter-spacing:.5px;}
.store-back .breadcrumb span{color:rgba(201,168,76,.6);}

.store-hero{padding:64px 5%;text-align:center;position:relative;overflow:hidden;}
.store-hero h1{font-size:clamp(2.5rem,6vw,5rem);letter-spacing:2px;margin-bottom:8px;}
.store-hero .store-tagline{font-size:12px;letter-spacing:2px;text-transform:uppercase;opacity:.5;margin-bottom:16px;}
.store-hero .store-sub{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.2rem;opacity:.4;}

/* 13Esthetics — spa/futuristic */
#view-esthetics{background:#F8F9FB;}
#view-esthetics .store-back{background:#F8F9FB;}
#view-esthetics .store-back button{border-color:rgba(0,0,0,.2);color:#5A4030;}
#view-esthetics .store-back button:hover{background:#5A4030;color:var(--wht);}
#view-esthetics .store-back .breadcrumb{color:rgba(0,0,0,.3);}
#view-esthetics .store-hero{background:linear-gradient(160deg,#0A0D12 0%,#14181E 50%,#0A0A12 100%);}
#view-esthetics .store-hero h1{color:var(--wht);}
#view-esthetics .store-hero .store-tagline{color:rgba(201,168,76,.7);}
#view-esthetics .store-hero .store-sub{color:rgba(255,255,255,.4);}
.esthetics-edu{padding:60px 5%;background:#F8F9FB;}
.edu-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:20px;max-width:1100px;margin:32px auto 0;}
.edu-card{background:#fff;border:1px solid rgba(0,0,0,.06);padding:28px;text-align:center;}
.edu-card .edu-icon{font-size:2rem;margin-bottom:12px;}
.edu-card h3{font-family:'Cormorant Garamond',serif;font-size:1.1rem;color:#1A1A2E;margin-bottom:8px;}
.edu-card p{font-size:11px;color:#666;line-height:1.7;}
.esthetics-products{padding:60px 5%;background:#fff;}
.esthetics-products h2{font-family:'Cormorant Garamond',serif;font-size:2rem;color:#1A1A2E;text-align:center;margin-bottom:8px;}
.esthetics-products .lbl{color:var(--g);display:block;text-align:center;margin-bottom:8px;}

/* Boujhetto — glam boutique */
#view-boujhetto{background:#0D0810;}
#view-boujhetto .store-back{background:#0D0810;}
#view-boujhetto .store-hero{background:linear-gradient(160deg,#1A0820 0%,#2D0D35 50%,#1A0820 100%);}
#view-boujhetto .store-hero h1{color:var(--wht);}
#view-boujhetto .store-hero .store-tagline{color:rgba(201,168,76,.7);}
.boujhetto-products{padding:60px 5%;background:#0D0810;}
.boujhetto-products h2{font-family:'Cormorant Garamond',serif;font-size:2rem;color:var(--wht);text-align:center;}
.boujhetto-products .lbl{color:rgba(201,168,76,.6);display:block;text-align:center;margin-bottom:8px;}
.b-prod-card{background:rgba(255,255,255,.04);border:1px solid rgba(201,168,76,.15);padding:24px;cursor:pointer;transition:all .25s;text-align:center;}
.b-prod-card:hover{border-color:var(--g);background:rgba(201,168,76,.05);}
.b-prod-card .prod-img{background:rgba(255,255,255,.03);padding:20px 0;font-size:3rem;margin-bottom:16px;}
.b-prod-card .prod-cat{font-size:8px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.65);margin-bottom:5px;}
.b-prod-card .prod-name{font-family:'Cormorant Garamond',serif;font-size:1.05rem;color:var(--wht);margin-bottom:8px;}
.b-prod-card .prod-price{font-family:'Cormorant Garamond',serif;font-size:1.15rem;color:var(--g);}

/* Carbonelle — jewelry showroom */
#view-carbonelle{background:#080810;}
#view-carbonelle .store-back{background:#080810;}
#view-carbonelle .store-hero{background:linear-gradient(160deg,#050508 0%,#0D0D18 50%,#050508 100%);}
#view-carbonelle .store-hero h1{background:linear-gradient(135deg,var(--g) 0%,#E8C97A 50%,var(--g) 100%);background-size:200% auto;-webkit-background-clip:text;-webkit-text-fill-color:transparent;animation:shimmer 4s linear infinite;}
#view-carbonelle .store-hero .store-tagline{color:rgba(201,168,76,.55);}
.carbonelle-products{padding:60px 5%;background:#080810;}
.carbonelle-products h2{font-family:'Cormorant Garamond',serif;font-size:2rem;color:var(--wht);text-align:center;}
.carbonelle-products .lbl{color:rgba(201,168,76,.55);display:block;text-align:center;margin-bottom:8px;}
.c-prod-card{background:rgba(255,255,255,.02);border:1px solid rgba(201,168,76,.1);padding:28px;cursor:pointer;transition:all .3s;text-align:center;position:relative;overflow:hidden;}
.c-prod-card::after{content:'';position:absolute;inset:-1px;border:1px solid transparent;transition:border-color .3s;}
.c-prod-card:hover{background:rgba(201,168,76,.04);}
.c-prod-card:hover::after{border-color:var(--g);}
.c-prod-card .prod-img{font-size:3rem;padding:20px 0;margin-bottom:16px;}
.c-prod-card .prod-cat{font-size:8px;letter-spacing:2px;text-transform:uppercase;color:rgba(201,168,76,.5);margin-bottom:5px;}
.c-prod-card .prod-name{font-family:'Cormorant Garamond',serif;font-size:1.1rem;color:var(--wht);margin-bottom:8px;}
.c-prod-card .prod-price{font-family:'Cormorant Garamond',serif;font-size:1.2rem;color:var(--g);}

/* ═══ LOUNGE ═══════════════════════════════════════════════════ */
#view-lounge{background:var(--blk);}
#view-lounge .store-back{background:var(--blk);}
.lounge-hero{padding:80px 5%;background:var(--blks);text-align:center;border-bottom:1px solid var(--gl);}
.lounge-hero h1{font-size:clamp(2.5rem,5vw,4rem);color:var(--wht);margin-bottom:8px;}
.lounge-hero p{font-size:13px;color:rgba(255,255,255,.35);max-width:460px;margin:0 auto;line-height:1.8;}
.lounge-content{padding:60px 5%;}
.lounge-section{margin-bottom:64px;}
.lounge-section h2{font-family:'Cormorant Garamond',serif;font-size:2rem;color:var(--wht);text-align:center;margin-bottom:8px;}
.lounge-section .lbl{color:rgba(201,168,76,.55);display:block;text-align:center;margin-bottom:8px;}
.campaign-row{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px;margin-top:32px;max-width:1100px;margin-left:auto;margin-right:auto;}
.campaign-big{background:var(--blks);border:1px solid rgba(201,168,76,.12);padding:36px;text-align:center;transition:border-color .25s;}
.campaign-big:hover{border-color:var(--g);}
.campaign-big .c-icon{font-size:2.5rem;margin-bottom:16px;}
.campaign-big h3{font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:var(--wht);margin-bottom:8px;}
.campaign-big p{font-size:11px;color:rgba(255,255,255,.3);line-height:1.7;margin-bottom:16px;}

/* ═══ DRESSING ROOM ════════════════════════════════════════════ */
#view-dressing{background:#0A0814;}
#view-dressing .store-back{background:#0A0814;}
.dressing-hero{padding:56px 5%;background:#070610;text-align:center;border-bottom:1px solid rgba(201,168,76,.1);}
.dressing-hero h1{font-size:clamp(2rem,4vw,3.5rem);color:var(--wht);margin-bottom:8px;}
.dressing-hero p{font-size:11px;color:rgba(255,255,255,.3);letter-spacing:1.5px;text-transform:uppercase;}
.dressing-content{padding:48px 5%;display:grid;grid-template-columns:1fr 1fr;gap:40px;max-width:1000px;margin:0 auto;}
.upload-zone{border:1px dashed rgba(201,168,76,.35);min-height:400px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;position:relative;overflow:hidden;transition:border-color .25s;}
.upload-zone:hover{border-color:var(--g);}
.upload-zone img.preview{width:100%;height:100%;object-fit:contain;position:absolute;inset:0;}
.upload-zone .upload-overlay{position:absolute;inset:0;background:rgba(10,8,20,.5);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .3s;}
.upload-zone:hover .upload-overlay{opacity:1;}
.upload-placeholder{text-align:center;padding:20px;position:relative;z-index:1;}
.upload-placeholder .up-icon{font-size:3rem;opacity:.25;margin-bottom:12px;}
.upload-placeholder p{font-size:12px;color:rgba(255,255,255,.25);margin-bottom:4px;}
.upload-placeholder small{font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,.15);}
.try-panel h3{font-family:'Cormorant Garamond',serif;font-size:1.4rem;color:var(--wht);margin-bottom:5px;}
.try-panel p.sub{font-size:10px;color:rgba(255,255,255,.3);margin-bottom:20px;letter-spacing:.5px;}
.try-item{display:flex;align-items:center;gap:14px;padding:13px;border:1px solid rgba(255,255,255,.07);margin-bottom:10px;cursor:pointer;transition:all .2s;}
.try-item:hover,.try-item.active{border-color:var(--g);background:rgba(201,168,76,.06);}
.try-item .ti-icon{font-size:1.8rem;width:44px;text-align:center;}
.try-item h4{font-size:12px;color:var(--wht);margin-bottom:2px;}
.try-item p{font-size:10px;color:rgba(255,255,255,.3);}
.try-item .ti-check{margin-left:auto;font-size:10px;color:var(--g);display:none;}
.try-item.active .ti-check{display:block;}
.privacy-note{background:rgba(201,168,76,.04);border:1px solid rgba(201,168,76,.12);padding:14px;margin-top:20px;}
.privacy-note p{font-size:10px;color:rgba(255,255,255,.25);line-height:1.7;}
.privacy-note .lbl{color:rgba(255,255,255,.2);display:block;margin-bottom:5px;}
.try-on-overlay{position:absolute;pointer-events:none;font-size:3rem;transition:all .2s;}

/* ═══ PRODUCT MODAL ════════════════════════════════════════════ */
#prod-modal{position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:1000;display:none;align-items:center;justify-content:center;padding:20px;}
#prod-modal.open{display:flex;}
.modal-box{background:var(--wht);max-width:480px;width:100%;position:relative;max-height:90vh;overflow-y:auto;}
.modal-close{position:absolute;top:14px;right:16px;background:none;border:none;font-size:18px;cursor:pointer;color:var(--blk);z-index:1;line-height:1;}
.modal-img{background:var(--champ);padding:32px;text-align:center;font-size:4rem;}
.modal-body{padding:28px;}
.modal-body .lbl{color:var(--g);display:block;margin-bottom:5px;}
.modal-body h2{font-family:'Cormorant Garamond',serif;font-size:1.8rem;color:var(--blk);margin-bottom:10px;}
.modal-body p{font-size:13px;color:#555;line-height:1.7;margin-bottom:16px;}
.modal-price{font-family:'Cormorant Garamond',serif;font-size:1.7rem;color:var(--g);margin-bottom:24px;}
.modal-actions{display:flex;flex-direction:column;gap:10px;}
.modal-actions button{padding:13px;font-family:'Inter',sans-serif;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;transition:all .25s;}
.modal-act-primary{background:var(--blk);color:var(--wht);border:none;}
.modal-act-primary:hover{background:#333;}
.modal-act-outline{background:transparent;color:var(--blk);border:1px solid var(--blk);}
.modal-act-outline:hover{background:var(--blk);color:var(--wht);}
.modal-act-wish{background:transparent;color:var(--g);border:1px solid var(--g);}
.modal-act-wish:hover{background:var(--g);color:var(--blk);}
.modal-act-wish.wishlisted{background:var(--g);color:var(--blk);}

/* ═══ WISHLIST PANEL ══════════════════════════════════════════ */
#wish-panel{position:fixed;top:0;right:-400px;width:380px;height:100vh;background:var(--blks);z-index:2000;transition:right .4s cubic-bezier(.25,.46,.45,.94);border-left:1px solid var(--gl);overflow-y:auto;}
#wish-panel.open{right:0;}
#wish-overlay{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:1999;display:none;}
#wish-overlay.open{display:block;}
.wish-header{padding:20px 20px 16px;border-bottom:1px solid rgba(255,255,255,.08);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--blks);}
.wish-header h3{font-family:'Cormorant Garamond',serif;font-size:1.4rem;color:var(--wht);}
.wish-close-btn{background:none;border:none;font-size:18px;color:rgba(255,255,255,.4);cursor:pointer;}
.wish-items{padding:16px;}
.wish-item{display:flex;align-items:center;gap:14px;padding:14px;border:1px solid rgba(255,255,255,.06);margin-bottom:10px;}
.wish-item .wi-icon{font-size:2rem;width:50px;text-align:center;background:rgba(255,255,255,.04);padding:8px 0;}
.wi-info h4{font-size:12px;color:var(--wht);margin-bottom:3px;}
.wi-info p{font-size:10px;color:var(--tan);}
.wi-remove{margin-left:auto;background:none;border:none;font-size:12px;color:rgba(255,255,255,.2);cursor:pointer;transition:color .2s;}
.wi-remove:hover{color:#e74c3c;}
.wish-empty{text-align:center;padding:60px 20px;}
.wish-empty .we-icon{font-size:3rem;opacity:.2;margin-bottom:12px;}
.wish-empty p{font-size:12px;color:rgba(255,255,255,.25);}

/* RESPONSIVE */
@media(max-width:768px){
  .nav-links{display:none;}
  .doors-grid{grid-template-columns:1fr 1fr;}
  .store-door{height:260px;}
  .dressing-content{grid-template-columns:1fr;}
  .upload-zone{min-height:280px;}
  #wish-panel{width:100%;right:-100%;}
}
@media(max-width:480px){
  .doors-grid{grid-template-columns:1fr;}
  .products-grid,.campaign-row,.campaign-grid{grid-template-columns:1fr;}
}
