// ── STATE ─────────────────────────────────────────────────────
var wishlist = [];
var currentView = 'lobby';
var currentProduct = null;
var bag = 0;

// ── PARTICLES ─────────────────────────────────────────────────
function makeParticles(){
  var el = document.getElementById('particles');
  if(!el) return;
  for(var i=0;i<28;i++){
    var p = document.createElement('div');
    p.className = 'particle';
    p.style.left = Math.random()*100+'%';
    p.style.top = Math.random()*100+'%';
    p.style.animationDelay = (Math.random()*4)+'s';
    p.style.animationDuration = (3+Math.random()*4)+'s';
    p.style.opacity = (0.1+Math.random()*0.4).toString();
    el.appendChild(p);
  }
}

// ── NAVIGATION ────────────────────────────────────────────────
function navigate(viewId){
  if(viewId === currentView) return;
  var ov = document.getElementById('overlay');
  ov.classList.add('on');
  setTimeout(function(){
    document.querySelectorAll('.view').forEach(function(v){v.classList.remove('active');});
    var el = document.getElementById('view-'+viewId);
    if(el){ el.classList.add('active'); }
    currentView = viewId;
    window.scrollTo(0,0);
    setTimeout(function(){ ov.classList.remove('on'); }, 50);
  }, 450);
}

// ── RENDER PRODUCTS ───────────────────────────────────────────
function renderProducts(containerId, items, darkMode){
  var el = document.getElementById(containerId);
  if(!el) return;
  el.innerHTML = '';
  items.forEach(function(p){
    var card = document.createElement('div');
    if(darkMode){
      card.className = darkMode === 'carbonelle' ? 'c-prod-card' : 'b-prod-card';
    } else {
      card.className = 'prod-card';
    }
    if(darkMode){
      card.innerHTML =
        '<div class="prod-img">'+p.icon+'</div>'+
        '<div class="prod-cat">'+p.cat+'</div>'+
        '<div class="prod-name">'+p.name+'</div>'+
        '<div class="prod-price">$'+p.price+'</div>';
    } else {
      card.innerHTML =
        '<div class="prod-img">'+p.icon+'</div>'+
        '<div class="prod-cat">'+p.cat+'</div>'+
        '<div class="prod-name">'+p.name+'</div>'+
        (p.store?'<div class="prod-store">'+p.store+'</div>':'')+
        '<div class="prod-price">$'+p.price+'</div>'+
        '<div class="prod-action">View · Add to Bag</div>';
    }
    card.addEventListener('click', function(){ openModal(p); });
    el.appendChild(card);
  });
}

// ── MODAL ─────────────────────────────────────────────────────
function openModal(p){
  currentProduct = p;
  document.getElementById('modal-icon').textContent = p.icon;
  document.getElementById('modal-cat').textContent = p.cat + (p.store?' · '+p.store:'');
  document.getElementById('modal-name').textContent = p.name;
  document.getElementById('modal-desc').textContent = p.desc;
  document.getElementById('modal-price').textContent = '$'+p.price+'.00';
  var wb = document.getElementById('wish-btn');
  var inList = wishlist.find(function(w){return w.id===p.id;});
  wb.textContent = inList ? '♥ Wishlisted' : '♡ Save to Wishlist';
  wb.className = 'modal-act-wish' + (inList?' wishlisted':'');
  document.getElementById('prod-modal').classList.add('open');
}
function closeModal(e){
  if(!e || e.target===document.getElementById('prod-modal') || e.target===document.querySelector('.modal-close')){
    document.getElementById('prod-modal').classList.remove('open');
    currentProduct = null;
  }
}
function addToBag(){
  bag++;
  document.getElementById('prod-modal').classList.remove('open');
  showToast('Added to bag!');
}
function toggleWish(){
  if(!currentProduct) return;
  var idx = wishlist.findIndex(function(w){return w.id===currentProduct.id;});
  if(idx > -1){
    wishlist.splice(idx,1);
    showToast('Removed from wishlist');
  } else {
    wishlist.push(currentProduct);
    showToast('Saved to wishlist ♥');
  }
  updateWishUI();
  var wb = document.getElementById('wish-btn');
  var inList = wishlist.find(function(w){return w.id===currentProduct.id;});
  wb.textContent = inList ? '♥ Wishlisted' : '♡ Save to Wishlist';
  wb.className = 'modal-act-wish'+(inList?' wishlisted':'');
}

// ── WISHLIST ──────────────────────────────────────────────────
function toggleWishlist(){
  document.getElementById('wish-panel').classList.toggle('open');
  document.getElementById('wish-overlay').classList.toggle('open');
}
function updateWishUI(){
  document.getElementById('wish-count').textContent = wishlist.length;
  var el = document.getElementById('wish-items');
  if(!wishlist.length){
    el.innerHTML = '<div class="wish-empty"><div class="we-icon">♡</div><p>Your wishlist is empty.<br>Heart items to save them here.</p></div>';
    return;
  }
  el.innerHTML = '';
  wishlist.forEach(function(p){
    var item = document.createElement('div');
    item.className = 'wish-item';
    item.innerHTML =
      '<div class="wi-icon">'+p.icon+'</div>'+
      '<div class="wi-info"><h4>'+p.name+'</h4><p>$'+p.price+'</p></div>'+
      '<button class="wi-remove" onclick="removeWish(\''+p.id+'\')">✕</button>';
    el.appendChild(item);
  });
}
function removeWish(id){
  wishlist = wishlist.filter(function(w){return w.id!==id;});
  updateWishUI();
}

// ── TOAST ─────────────────────────────────────────────────────
function showToast(msg){
  var t = document.createElement('div');
  t.style.cssText = 'position:fixed;bottom:28px;left:50%;transform:translateX(-50%);background:#C9A84C;color:#0A0A0A;padding:10px 24px;font-size:11px;letter-spacing:1px;z-index:9999;animation:fadeUp .3s ease;font-family:Inter,sans-serif;';
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(function(){t.remove();},2200);
}

// ── DRESSING ROOM ─────────────────────────────────────────────
function buildTryItems(){
  var el = document.getElementById('try-items-list');
  if(!el) return;
  DATA.tryOn.forEach(function(item){
    var div = document.createElement('div');
    div.className = 'try-item';
    div.id = 'try-'+item.id;
    div.innerHTML =
      '<div class="ti-icon">'+item.icon+'</div>'+
      '<div><h4>'+item.name+'</h4><p>Click to try on</p></div>'+
      '<span class="ti-check">✓</span>';
    div.addEventListener('click', function(){ toggleTryItem(item); div.classList.toggle('active'); });
    el.appendChild(div);
  });
}
function handleUpload(input){
  var file = input.files[0];
  if(!file) return;
  var url = URL.createObjectURL(file);
  var img = document.getElementById('preview-img');
  img.src = url;
  img.style.display = 'block';
  document.getElementById('upload-placeholder').style.display = 'none';
  document.getElementById('clear-photo-btn').style.display = 'block';
  document.getElementById('no-photo-hint').style.display = 'none';
}
function clearPhoto(){
  document.getElementById('preview-img').style.display = 'none';
  document.getElementById('preview-img').src = '';
  document.getElementById('upload-placeholder').style.display = 'block';
  document.getElementById('clear-photo-btn').style.display = 'none';
  document.getElementById('no-photo-hint').style.display = 'block';
  document.getElementById('try-on-layer').innerHTML = '';
  document.querySelectorAll('.try-item').forEach(function(t){t.classList.remove('active');});
  document.getElementById('file-input').value = '';
}
function toggleTryItem(item){
  var layer = document.getElementById('try-on-layer');
  var existing = document.getElementById('ov-'+item.id);
  if(existing){ existing.remove(); return; }
  var ov = document.createElement('div');
  ov.id = 'ov-'+item.id;
  ov.style.cssText = 'position:absolute;top:'+item.top+';left:'+item.left+';width:'+item.w+';font-size:3.5rem;text-align:center;pointer-events:none;filter:drop-shadow(0 2px 8px rgba(0,0,0,.4));';
  ov.textContent = item.icon;
  layer.appendChild(ov);
}

// ── LOUNGE PICKS ──────────────────────────────────────────────
function renderLoungePicks(){
  var el = document.getElementById('lounge-picks');
  if(!el) return;
  var picks = [DATA.floor[0], DATA.esthetics[0], DATA.carbonelle[0]];
  var grid = document.createElement('div');
  grid.style.cssText = 'display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:20px;margin-top:32px;';
  picks.forEach(function(p){
    var card = document.createElement('div');
    card.style.cssText = 'background:rgba(255,255,255,.03);border:1px solid rgba(201,168,76,.1);padding:28px;text-align:center;cursor:pointer;transition:border-color .25s;';
    card.innerHTML = '<div style="font-size:3rem;margin-bottom:14px;">'+p.icon+'</div>'
      +'<div style="font-size:8px;letter-spacing:2px;text-transform:uppercase;color:#C9A84C;margin-bottom:5px;">'+p.cat+'</div>'
      +'<div style="font-family:Cormorant Garamond,serif;font-size:1.1rem;color:#FAFAF8;margin-bottom:6px;">'+p.name+'</div>'
      +'<div style="font-family:Cormorant Garamond,serif;color:#C9A84C;">$'+p.price+'</div>';
    card.addEventListener('mouseenter',function(){this.style.borderColor='#C9A84C';});
    card.addEventListener('mouseleave',function(){this.style.borderColor='rgba(201,168,76,.1)';});
    card.addEventListener('click',function(){openModal(p);});
    grid.appendChild(card);
  });
  el.appendChild(grid);
}

// ── INIT ──────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', function(){
  makeParticles();
  renderProducts('floor-products', DATA.floor, false);
  renderProducts('esthetics-products', DATA.esthetics, false);
  renderProducts('boujhetto-products', DATA.boujhetto, 'boujhetto');
  renderProducts('carbonelle-products', DATA.carbonelle, 'carbonelle');
  renderLoungePicks();
  buildTryItems();
});
</script>
